# ─────────────────────────────────────────────────────────────────────────────
# TaskFlow Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ── Supabase PostgreSQL ───────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=24h

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Frontend URL (for CORS and email links)
# In production: set this to your Netlify URL e.g. https://taskflow.netlify.app
CLIENT_URL=http://localhost:3000

# ── Email (Nodemailer SMTP) ───────────────────────────────────────────────────
# For Gmail: use an App Password (Google Account → Security → App Passwords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="TaskFlow" <your_email@gmail.com>

# ── Supabase Storage (for file attachments) ───────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
# Use the SERVICE ROLE key — not the anon key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key
SUPABASE_BUCKET=taskflow-attachments
