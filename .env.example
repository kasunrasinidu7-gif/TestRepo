# .env.example  (project root — used by docker-compose.yml)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to .env in the project root before running docker-compose up.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection string
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="TaskFlow" <your_email@gmail.com>
